{
  "default": {
    "require": [
      "tests/hooks/world.ts",
      "tests/hooks/db.setup.ts",
      "tests/hooks/hooks.ts",
      "tests/step_definitions/**/*.steps.ts"
    ],

    "requireModule": [
      "ts-node/register"
    ],
    "format": [
      "progress-bar",
      "allure-cucumberjs/reporter:allure-dummy.txt"
    ],
    "formatOptions": {
