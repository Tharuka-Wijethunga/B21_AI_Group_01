{
  "name": "b21-ai-group-01-tests",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "test": "cucumber-js \"tests/features/**/*.feature\"",
    "test:api": "cucumber-js \"tests/features/api/**/*.feature\"",
    "test:ui": "cucumber-js \"tests/features/ui/**/*.feature\"",
    "test:admin": "cucumber-js --tags \"@admin\"",
    "test:user": "cucumber-js --tags \"@user\"",
    "test:sales": "cucumber-js tests/features/api/admin/sales.feature tests/features/api/user/sales.feature tests/features/ui/admin/sales.feature tests/features/ui/user/sales.feature",
    "db:reset": "ts-node tests/hooks/reset-db.ts",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "allure:report": "npm run allure:generate && npm run allure:open"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^10.8.0",
    "@playwright/test": "^1.60.0",
    "@types/node": "^20.14.0",
    "allure-commandline": "^2.42.1",
    "allure-cucumberjs": "^3.10.0",
    "dotenv": "^16.4.5",
    "mysql2": "^3.10.0",
    "playwright": "^1.44.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
