{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "outDir": "dist",
    "rootDir": ".",
    "skipLibCheck": true,
    "baseUrl": "."
  },
  "include": ["tests/**/*.ts"],
  "exclude": ["node_modules", "dist", "allure-results", "allure-report"]
}
